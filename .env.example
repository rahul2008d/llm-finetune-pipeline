# =============================================================================
# LLM Fine-Tuning Pipeline - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env with real credentials.
# =============================================================================

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ACCOUNT_ID=123456789012

# --- S3 Buckets ---
S3_BUCKET_DATA=your-data-bucket
S3_BUCKET_MODELS=your-models-bucket
S3_BUCKET_ARTIFACTS=your-artifacts-bucket

# --- SageMaker ---
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerExecutionRole
SAGEMAKER_INSTANCE_TYPE=ml.g5.2xlarge
SAGEMAKER_ENDPOINT_NAME=llm-finetune-endpoint

# --- Model Configuration ---
BASE_MODEL_ID=meta-llama/Llama-2-7b-hf
HUGGINGFACE_TOKEN=hf_your_token_here

# --- Training Hyperparameters ---
TRAIN_EPOCHS=3
TRAIN_BATCH_SIZE=4
TRAIN_LEARNING_RATE=2e-4
TRAIN_LORA_RANK=64
TRAIN_LORA_ALPHA=128

# --- Monitoring ---
CLOUDWATCH_NAMESPACE=LLMFineTuning
CLOUDWATCH_LOG_GROUP=/llm-finetune-pipeline
ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:llm-alerts

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
