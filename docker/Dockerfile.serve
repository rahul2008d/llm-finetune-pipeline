# syntax=docker/dockerfile:1
ARG AWS_REGION=us-east-1
FROM 763104351884.dkr.ecr.${AWS_REGION}.amazonaws.com/huggingface-pytorch-inference:2.2.0-transformers4.44.0-gpu-py310-cu121-ubuntu22.04

# ── Environment ──────────────────────────────────────────────────────────────
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    HF_HOME=/tmp/hf_cache \
    TRANSFORMERS_CACHE=/tmp/hf_cache

# ── Serving dependencies only ────────────────────────────────────────────────
COPY pyproject.toml /tmp/pyproject.toml
RUN pip install --no-cache-dir \
    pydantic>=2.8.0 \
    pydantic-settings>=2.4.0 \
    structlog>=24.1.0 \
    boto3>=1.34.0 \
    sagemaker>=2.225.0 \
    tenacity>=8.2.0 \
    && rm /tmp/pyproject.toml

# ── Application code ─────────────────────────────────────────────────────────
COPY src/serving/ /opt/ml/code/src/serving/
COPY src/utils/ /opt/ml/code/src/utils/
COPY src/config/ /opt/ml/code/src/config/
COPY src/__init__.py /opt/ml/code/src/__init__.py

WORKDIR /opt/ml/code

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c 'import src.serving.endpoint'

ENTRYPOINT ["python", "-m", "src.serving.handler"]
